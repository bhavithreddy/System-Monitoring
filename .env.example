# =============================================================================
# system-monitor — Environment Configuration
# Copy this to .env and edit values. Never commit .env to version control.
# =============================================================================

# ── Paths (auto-detected if left as-is) ──────────────────────────────────────
# DATA_FILE=/path/to/system-monitor/data/metrics.json
# LOG_FILE=/path/to/system-monitor/logs/health_check.log

# ── Services to monitor (comma-separated systemd unit names) ─────────────────
MONITORED_SERVICES=ssh,cron,networking

# ── Alert Thresholds ──────────────────────────────────────────────────────────
ALERT_CPU_THRESHOLD=85
ALERT_MEM_THRESHOLD=85
ALERT_DISK_THRESHOLD=90

# ── Cooldown (seconds between repeated alerts for the same category) ──────────
ALERT_COOLDOWN_SECONDS=300

# ── Email Alerts ──────────────────────────────────────────────────────────────
# Requires: sudo apt install mailutils
# Leave blank to disable email alerts
ALERT_EMAIL=you@example.com
SMTP_FROM=monitor@yourdomain.com

# ── Slack Alerts ──────────────────────────────────────────────────────────────
# Create a webhook at: https://api.slack.com/messaging/webhooks
# Leave blank to disable Slack alerts
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ── Flask Backend ─────────────────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=false
